{
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "*.pdf": "pdf.preview",
    "*.md": "default",
    "{git,gitlens}:/**/*.{md,csv,svg}": "default",
  },
  "editor.fontFamily": "Maple Mono NF CN",
  "workbench.colorTheme": "Atom One Light",
  "workbench.sideBar.location": "right",
  "commentTranslate.hover.string": true,
  "commentTranslate.sourceLanguage": "en",
  "commentTranslate.targetLanguage": "zh-CN",
  "commentTranslate.maxTranslationLength": 200,
  "workbench.iconTheme": "material-icon-theme",
  "vscode-office.editorTheme": "Light",
  "editor.fontSize": 18,
  "explorer.confirmPasteNative": false,
  "explorer.confirmDragAndDrop": false,
  "hediet.vscode-drawio.resizeImages": null,
  "python.analysis.inlayHints.variableTypes": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "cmake.showOptionsMovedNotification": false,
  "git.autofetch": true,
  "git.enableSmartCommit": true,
  "explorer.confirmDelete": false,
  "cSpell.userWords": [
    "yiwencai"
  ],
  "markdown-preview-enhanced.codeBlockTheme": "github.css",
  "go.toolsManagement.autoUpdate": true,
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
  },
  "editor.lineNumbers": "on",
  "files.autoSave": "onFocusChange",
  "terminal.external.osxExec": "",
  "terminal.integrated.fontSize": 18,
  "errorLens.borderRadius": "0.3em",
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning"
  ],
  "errorLens.enableOnDiffView": true,
  "errorLens.gutterIconsEnabled": true,
  "editor.guides.bracketPairs": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.showContextMenu": true,
  "latex-workshop.intellisense.package.enabled": true,
  "latex-workshop.message.error.show": true,
  "latex-workshop.message.warning.show": false,
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-shell-escape",
        "%DOC%",
      ],
    },
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%",
      ],
    },
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "%DOC%",
      ],
    },
    {
      "name": "bibtex",
      "command": "bibtex",
      "args": [
        "%DOC%"
      ],
    },
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX",
      "tools": [
        "xelatex"
      ],
    },
    {
      "name": "PDFLaTeX",
      "tools": [
        "pdflatex"
      ],
    },
    {
      "name": "BibTeX",
      "tools": [
        "bibtex"
      ],
    },
    {
      "name": "LaTeXmk",
      "tools": [
        "latexmk"
      ],
    },
    {
      "name": "xelatex -> bibtex -> xelatex*2",
      "tools": [
        "xelatex",
        "bibtex",
        "xelatex",
        "xelatex"
      ],
    },
    {
      "name": "pdflatex -> bibtex -> pdflatex*2",
      "tools": [
        "pdflatex",
        "bibtex",
        "pdflatex",
        "pdflatex"
      ],
    },
  ],
  "latex-workshop.latex.clean.fileTypes": [
    "*.aux",
    "*.bbl",
    "*.blg",
    "*.idx",
    "*.ind",
    "*.lof",
    "*.lot",
    "*.out",
    "*.toc",
    "*.acn",
    "*.acr",
    "*.alg",
    "*.glg",
    "*.glo",
    "*.gls",
    "*.ist",
    "*.fls",
    "*.log",
    "*.fdb_latexmk",
  ],
  "latex-workshop.latex.autoClean.run": "onBuilt",
  "latex-workshop.latex.recipe.default": "lastUsed",
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click",
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.view.pdf.ref.viewer": "auto",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1,
  },
  "makefile.configureOnOpen": true,
  "redhat.telemetry.enabled": true,
  "window.zoomLevel": 0.5,
  "editor.fontLigatures": true,
  "cursor.cpp.enablePartialAccepts": true,
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": [
        "j",
        "k"
      ],
      "after": [
        "<Esc>"
      ],
    },
  ],
  "tinymist.formatterMode": "typstyle",
  "vim.easymotion": true,
  "vim.enableNeovim": true,
  "vim.leader": " ",
  "vim.neovimPath": "/opt/homebrew/bin/nvim",
  "vim.sneak": true,
  "vim.sneakUseIgnorecaseAndSmartcase": true,
  "vim.sneakReplacesF": true,
  "vim.useSystemClipboard": true,
  "security.workspace.trust.untrustedFiles": "open",
  "files.associations": {
    "*.flex": "lex",
    "*.asc": "cpp",
  },
  "editor.accessibilitySupport": "off",
  "chat.agent.enabled": true,
  "github.copilot.selectedCompletionModel": "",
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "c": false,
    "cpp": false,
    "go": false,
    "mermaid": false,
  },
  "editor.formatOnSave": true,
  "terminal.integrated.suggest.enabled": true,
  "kilo-code.allowedCommands": [
    "git log",
    "git diff",
    "git show"
  ],
  "kilo-code.deniedCommands": [],
  "chat.mcp.access": "none",
  "python.analysis.inlayHints.callArgumentNames": "partial",
  "workbench.editor.empty.hint": "hidden",
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "keyword",
        "settings": {
          "fontStyle": "bold",
        },
      },
      {
        "scope": "variable",
        "settings": {
          "fontStyle": "",
        },
      },
      {
        "scope": "entity.name.function",
        "settings": {
          "fontStyle": "bold",
        },
      },
      {
        "scope": "comment",
        "settings": {
          "fontStyle": "italic",
        },
      },
      {
        "scope": "entity.name.class",
        "settings": {
          "fontStyle": "bold",
        },
      },
    ],
  },
  "terminal.integrated.defaultProfile.osx": "zsh",
  "claudeCode.selectedModel": "default",
  "workbench.colorCustomizations": {},
  "window.titleBarStyle": "custom",
  "python.analysis.diagnosticsSource": "Pyright",
  "extensions.autoUpdate": "on",
  "extensions.autoCheckUpdates": true,
  "window.restoreWindows": "none",
  "remote.SSH.lockfilesInTmp": true,
  "remote.SSH.remoteServerListenOnSocket": true,
  "remote.SSH.connectTimeout": 300,
  "remote.SSH.remotePlatform": {
    "ModelArts-notebook-5122": "linux",
    "lab": "linux",
    "ict": "linux",
    "final": "linux",
    "a800": "linux",
    "h100": "linux"
  },
  "roo-cline.allowedCommands": [
    "git",
    "make",
    "cargo",
    "python3",
    "pip",
    "cmake",
    "g++",
    "gcc",
    "clang++",
    "clang",
    "git log",
    "git diff",
    "git show",
    "grep",
    "sed",
  ],
  "roo-cline.deniedCommands": [],
  "[cpp]": {},
  "roo-cline.debug": false,
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "/public/home/caiyiwen/.local/bin/zsh",
    },
  },
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontFamily": "Maple Mono NF CN",
  "claudeCode.preferredLocation": "panel",
  "git.openRepositoryInParentFolders": "never",
  "python-envs.defaultEnvManager": "",
  "workbench.secondarySideBar.showLabels": false,
  "cursor.cpp.disabledLanguages": [
    "plaintext",
    "markdown",
    "scminput",
    "c",
    "cpp",
    "go",
    "mermaid",
  ],
  "workbench.preferredLightColorTheme": "Catppuccin Mocha",
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.inlayHints.callArgumentNames": "partial",
  "cursorpyright.analysis.inlayHints.functionReturnTypes": true,
  "cursorpyright.analysis.inlayHints.variableTypes": true,
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "cursor.composer.usageSummaryDisplay": "always",
}